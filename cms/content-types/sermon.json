{
  "kind": "collectionType",
  "collectionName": "sermons",
  "info": {
    "singularName": "sermon",
    "pluralName": "sermons",
    "displayName": "Sermon",
    "description": "Sermon archive with video/audio"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "date": { "type": "date", "required": true },
    "speaker": { "type": "string" },
    "series": { "type": "string" },
    "description": { "type": "text" },
    "videoUrl": {
      "type": "string",
      "regex": "^https?://.*"
    },
    "audioUrl": {
      "type": "string",
      "regex": "^https?://.*"
    },
    "thumbnail": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "scriptureReference": { "type": "string" }
  }
}
