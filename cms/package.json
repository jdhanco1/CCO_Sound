{
  "name": "community-church-cms",
  "private": true,
  "version": "1.0.0",
  "description": "Payload CMS for Community Church Oxford",
  "scripts": {
    "dev": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts nodemon",
    "build:payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload build",
    "build:server": "tsc",
    "build": "npm run build:payload && npm run build:server",
    "serve": "cross-env PAYLOAD_CONFIG_PATH=dist/payload.config.js node dist/server.js",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types"
  },
  "dependencies": {
    "@payloadcms/bundler-webpack": "^1.0.7",
    "@payloadcms/db-postgres": "^0.8.7",
    "@payloadcms/richtext-lexical": "^0.12.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "payload": "^2.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "nodemonConfig": {
    "exec": "ts-node src/server.ts",
    "ext": "ts",
    "watch": ["src"]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
